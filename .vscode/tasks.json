{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "process",
            "label": "Java: javac build",
            "command": "javac",
            "args": [
                "-g",
                "${file}",
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
    ]
}
